---
import type { ScheduleDay } from "~/lib/scheduleData";

interface Props {
    days: ScheduleDay[];
}

const { days } = Astro.props;

const colorStyles = {
    cyan: {
        badge: "text-cyan-400",
        badgeGlow: "before:bg-cyan-400 before:shadow-cyan-400",
        border: "border-cyan-500/30",
    },
    purple: {
        badge: "text-purple-400",
        badgeGlow: "before:bg-purple-400 before:shadow-purple-400",
        border: "border-purple-500/30",
    },
    green: {
        badge: "text-emerald-400",
        badgeGlow: "before:bg-emerald-400 before:shadow-emerald-400",
        border: "border-emerald-500/30",
    },
};

function getTagColor(type: string) {
    switch (type) {
        case "moderator":
            return "bg-purple-500/20 text-purple-300 border-purple-400/30";
        case "speaker":
            return "bg-amber-500/20 text-amber-300 border-amber-400/30";
        case "staff":
            return "bg-cyan-500/20 text-cyan-300 border-cyan-400/30";
        case "volunteer":
            return "bg-blue-500/20 text-blue-300 border-blue-400/30";
        default:
            return "bg-slate-500/20 text-slate-300 border-slate-400/30";
    }
}
---

<div class="space-y-8">
    {
        days.map((day) => {
            const colors = colorStyles[day.color];
            return (
                <div class="backdrop-blur-xl bg-slate-900/40 border border-slate-700/50 rounded-2xl overflow-hidden shadow-2xl hover:shadow-3xl hover:border-slate-600/70 transition-all duration-300">
                    {/* Day Header */}
                    <div class="bg-gradient-to-r from-slate-800/50 to-transparent border-b border-slate-700/30 px-6 py-4 sm:px-8 sm:py-5 flex items-center justify-between gap-4">
                        <div class="flex items-center gap-4">
                            <div
                                class={`relative inline-flex items-center gap-3 text-xl sm:text-2xl font-display font-bold ${colors.badge} before:w-2 before:h-2 before:rounded-full before:shadow-lg`}
                            >
                                {day.date}
                            </div>
                            <div class="hidden sm:block border-l border-slate-600/40 pl-4">
                                <p class="text-sm font-semibold text-slate-300">
                                    {day.dayNumber}
                                </p>
                                <p class="text-sm text-slate-500">
                                    {day.theme}
                                </p>
                            </div>
                        </div>
                        <div class="text-right sm:text-left">
                            <span class="inline-block bg-slate-700/50 text-slate-300 text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full border border-slate-600/30">
                                {day.eventType}
                            </span>
                        </div>
                    </div>

                    {/* Activities Table */}
                    <div class="divide-y divide-slate-700/20">
                        {day.activities.map((activity, index) => (
                            <div class="flex flex-col sm:flex-row hover:bg-slate-800/20 transition-colors duration-200">
                                {/* Time Cell */}
                                <div class="flex-shrink-0 px-6 py-4 sm:py-6 sm:px-8 sm:w-32 border-b sm:border-b-0 sm:border-r border-slate-700/20 bg-slate-800/20">
                                    <p class="font-display text-sm font-semibold text-slate-400 whitespace-nowrap">
                                        {activity.time}
                                    </p>
                                </div>

                                {/* Info Cell */}
                                <div class="flex-grow px-6 py-4 sm:py-6 sm:px-8">
                                    <h3 class="text-base sm:text-lg font-semibold text-white mb-2">
                                        {activity.title}
                                    </h3>
                                    <p class="text-slate-400 text-sm sm:text-base leading-relaxed mb-3">
                                        {activity.description}
                                    </p>

                                    {/* Tags */}
                                    <div class="flex flex-wrap gap-2">
                                        {activity.tags.map((tag) => (
                                            <span
                                                class={`inline-block text-xs font-medium px-2.5 py-1 rounded-md border ${getTagColor(tag.type)}`}
                                            >
                                                {tag.label}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            );
        })
    }
</div>

<style>
    /* Glassmorphism enhancement */
    @supports (backdrop-filter: blur(1px)) {
        div {
            background-image: linear-gradient(
                135deg,
                rgba(148, 163, 184, 0.05) 0%,
                rgba(71, 85, 105, 0.05) 100%
            );
        }
    }

    /* Glow effect on hover */
    :global(.dark) div:hover {
        box-shadow:
            0 0 30px rgba(6, 182, 212, 0.1),
            0 0 60px rgba(124, 58, 237, 0.05);
    }
</style>
