---
import MainLayout from "~/layouts/MainLayout.astro";
import ScheduleGrid from "~/components/ScheduleGrid.astro";
import { dayColumnsEN } from "~/lib/scheduleData";
---

<MainLayout
  title="Program | CBS Symposium 2026"
  description="Complete symposium program"
  currentPage="program"
  lang="en"
>
  <!-- Header -->
  <header
    class="pt-32 pb-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto text-center"
  >
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-300 text-sm font-semibold mb-6 border border-blue-100 dark:border-blue-800"
    >
      <span class="w-2 h-2 rounded-full bg-lime-500 animate-pulse"></span>
      Live Event: March 5-7, 2026
    </div>
    <h1
      class="text-4xl md:text-6xl font-display font-bold mb-6 tracking-tight text-slate-900 dark:text-white"
    >
      I International Virtual <br class="hidden md:block" />
      <span
        class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent"
        >Synthetic Biology by CBS 2026</span
      >
    </h1>
    <p
      class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed"
    >
      Join the leading minds in synthetic biology across Latin America for three
      days of cutting-edge research, collaboration, and innovation at UNMSM.
    </p>
  </header>

  <!-- Thematic Days Section -->
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <!-- Thematic Days -->
    <section class="mb-20">
      <div class="text-center mb-12">
        <h2
          class="text-3xl md:text-4xl font-display font-bold text-slate-900 dark:text-white mb-4"
        >
          Thematic Days
        </h2>
        <p class="text-slate-600 dark:text-slate-400">
          Discover the three main pillars of the symposium
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Day 1 -->
        <div
          class="group rounded-2xl border border-blue-200 dark:border-blue-900/50 bg-gradient-to-br from-blue-50 to-blue-50/50 dark:from-blue-900/20 dark:to-blue-900/10 p-8 hover:shadow-lg hover:border-blue-400 dark:hover:border-blue-700 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-3 mb-4">
            <span
              class="material-icons text-3xl text-blue-600 dark:text-blue-400"
              >public</span
            >
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
                Day 01
              </h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">March 5</p>
            </div>
          </div>
          <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-3">
            Global Frontiers
          </h4>
          <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">
            Exploring the international perspective: latest trends in synthetic
            biology and global collaborations.
          </p>
          <div
            class="mt-4 pt-4 border-t border-blue-200 dark:border-blue-900/30"
          >
            <p class="text-xs text-blue-600 dark:text-blue-400 font-semibold">
              Sessions in English
            </p>
          </div>
        </div>

        <!-- Day 2 -->
        <div
          class="group rounded-2xl border border-red-200 dark:border-red-900/50 bg-gradient-to-br from-red-50 to-red-50/50 dark:from-red-900/20 dark:to-red-900/10 p-8 hover:shadow-lg hover:border-red-400 dark:hover:border-red-700 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-3 mb-4">
            <span class="material-icons text-3xl text-red-600 dark:text-red-400"
              >flag</span
            >
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
                Day 02
              </h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">March 6</p>
            </div>
          </div>
          <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-3">
            Peruvian Research Hub
          </h4>
          <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">
            Focus on Peruvian research: leveraging unique genetic resources,
            local solutions to global problems, and innovation opportunities in
            Peru.
          </p>
          <div class="mt-4 pt-4 border-t border-red-200 dark:border-red-900/30">
            <p class="text-xs text-red-600 dark:text-red-400 font-semibold">
              Sessions in Spanish
            </p>
          </div>
        </div>

        <!-- Day 3 -->
        <div
          class="group rounded-2xl border border-green-200 dark:border-green-900/50 bg-gradient-to-br from-green-50 to-green-50/50 dark:from-green-900/20 dark:to-green-900/10 p-8 hover:shadow-lg hover:border-green-400 dark:hover:border-green-700 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-3 mb-4">
            <span
              class="material-icons text-3xl text-green-600 dark:text-green-400"
              >diversity_3</span
            >
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
                Day 03
              </h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">March 7</p>
            </div>
          </div>
          <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-3">
            LatAm Ecosystem
          </h4>
          <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">
            Uniting Latin America: innovation ecosystems, regional
            collaboration, shared infrastructure, and building a unified SynBio
            network.
          </p>
          <div
            class="mt-4 pt-4 border-t border-green-200 dark:border-green-900/30"
          >
            <p class="text-xs text-green-600 dark:text-green-400 font-semibold">
              Sessions in Spanish
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Detailed Schedule Section -->
    <section class="mb-20">
      <div class="text-center mb-16">
        <h2
          class="text-3xl md:text-4xl font-display font-bold text-slate-900 dark:text-white mb-4"
        >
          Detailed Schedule
        </h2>
        <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          Explore the complete program day by day with keynote speeches,
          thematic panels, workshops and specialized roundtable discussions on
          Friday and Saturday.
        </p>
      </div>

      <ScheduleGrid days={dayColumnsEN} lang="en" />
    </section>

    <!-- Panel Discussions Section -->
    <section>
      <div class="text-center mb-12">
        <h2
          class="text-3xl md:text-4xl font-display font-bold text-slate-900 dark:text-white mb-4"
        >
          Panel Discussions
        </h2>
        <p class="text-slate-600 dark:text-slate-400">
          Specialized dialogue spaces and collaboration
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Conversatorio 1 -->
        <div
          class="bg-gradient-to-br from-blue-900 to-blue-600 dark:from-blue-800 dark:to-cyan-600 rounded-2xl p-8 shadow-lg text-white relative overflow-hidden group cursor-pointer hover:shadow-xl transition-all"
        >
          <div
            class="absolute top-0 right-0 -mt-10 -mr-10 h-40 w-40 rounded-full bg-white opacity-5 group-hover:opacity-10 transition-opacity"
          >
          </div>

          <div class="relative z-10">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-icons text-lime-400">forum</span>
              <span
                class="text-lime-400 font-bold uppercase tracking-wide text-xs"
                >Panel Discussion</span
              >
            </div>

            <h3 class="text-2xl font-bold mb-4">
              The Future of International Collaboration
            </h3>

            <p class="text-blue-100 mb-6 leading-relaxed">
              A roundtable discussion on bridging the gap between Latin American
              research institutes and global leaders. We'll explore
              partnerships, funding, and collaboration opportunities.
            </p>

            <div class="flex flex-wrap gap-2 pt-4 border-t border-blue-400/30">
              <span
                class="inline-block px-3 py-1 bg-blue-500/30 rounded-full text-xs text-blue-200 font-medium"
                >International Networks</span
              >
              <span
                class="inline-block px-3 py-1 bg-blue-500/30 rounded-full text-xs text-blue-200 font-medium"
                >Funding</span
              >
              <span
                class="inline-block px-3 py-1 bg-blue-500/30 rounded-full text-xs text-blue-200 font-medium"
                >Collaboration</span
              >
            </div>
          </div>
        </div>

        <!-- Conversatorio 2 -->
        <div
          class="bg-gradient-to-br from-green-900 to-green-600 dark:from-green-800 dark:to-emerald-500 rounded-2xl p-8 shadow-lg text-white relative overflow-hidden group cursor-pointer hover:shadow-xl transition-all"
        >
          <div
            class="absolute top-0 right-0 -mt-10 -mr-10 h-40 w-40 rounded-full bg-white opacity-5 group-hover:opacity-10 transition-opacity"
          >
          </div>

          <div class="relative z-10">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-icons text-lime-400">forum</span>
              <span
                class="text-lime-400 font-bold uppercase tracking-wide text-xs"
                >Panel Discussion</span
              >
            </div>

            <h3 class="text-2xl font-bold mb-4">
              Challenges for Synthetic Biology in Peru
            </h3>

            <p class="text-green-100 mb-6 leading-relaxed">
              Discussing regulatory frameworks, funding opportunities, public
              policies, and the roadmap for bio-innovation in Peru. A space to
              envision the future together.
            </p>

            <div class="flex flex-wrap gap-2 pt-4 border-t border-green-400/30">
              <span
                class="inline-block px-3 py-1 bg-green-500/30 rounded-full text-xs text-green-200 font-medium"
                >Regulation</span
              >
              <span
                class="inline-block px-3 py-1 bg-green-500/30 rounded-full text-xs text-green-200 font-medium"
                >Public Policy</span
              >
              <span
                class="inline-block px-3 py-1 bg-green-500/30 rounded-full text-xs text-green-200 font-medium"
                >Local Ecosystem</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
